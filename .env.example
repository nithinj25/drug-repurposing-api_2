# ============================================================================
# Drug Repurposing Assistant - API Configuration
# ============================================================================
# Copy this file to .env and fill in your actual API keys
# Keep .env file secure and never commit it to git!
# ============================================================================

# ============================================================================
# 🤖 AI/LLM API KEYS (Choose ONE - Groq is Recommended for Free Tier)
# ============================================================================

# Option 1: GROQ API (RECOMMENDED - Fast & Free Tier Available)
# Get your key at: https://console.groq.com/keys
# Free tier: 30 requests/minute
USE_GROQ=true
GROQ_API_KEY=your_groq_api_key_here

# Option 2: OpenAI API (Paid but High Quality)
# Get your key at: https://platform.openai.com/api-keys
# Costs: ~$0.0001-0.0005 per request (gpt-4o-mini)
# OPENAI_API_KEY=your_openai_api_key_here


# ============================================================================
# 📚 LITERATURE & RESEARCH APIs (All FREE - No Key Required Usually)
# ============================================================================

# NCBI E-utilities API (PubMed/PMC)
# Optional: Get API key at https://www.ncbi.nlm.nih.gov/account/
# Increases rate limit from 3 to 10 requests/second
# Leave empty to use without key (slower rate limit)
NCBI_API_KEY=6666f0cc4d2e4a317f40f714f84c76355408

# Email for NCBI (Required for courtesy - they may contact you if issues)
NCBI_EMAIL=nithinj326@gmail.com


# ============================================================================
# 🏥 CLINICAL TRIALS APIs (FREE - No Key Required)
# ============================================================================

# ClinicalTrials.gov API v2
# No API key needed - public API
# Rate limit: Be respectful, ~1 request/second recommended
CLINICALTRIALS_API_URL=https://clinicaltrials.gov/api/v2


# ============================================================================
# 🧬 MOLECULAR & CHEMICAL DATABASE APIs (FREE)
# ============================================================================

# PubChem API (No key required)
PUBCHEM_API_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug

# ChEMBL API (No key required)
CHEMBL_API_URL=https://www.ebi.ac.uk/chembl/api/data

# Open Targets GraphQL API (No key required)
OPENTARGETS_API_URL=https://api.platform.opentargets.org/api/v4/graphql

# DisGeNET API (Disease-gene associations)
# 🔑 HOW TO GET: Register at https://www.disgenet.org/signup/
# Free academic tier available after email verification
# API docs: https://www.disgenet.org/api/
DISGENET_API_KEY=c1b64a91-e016-4db1-9a3c-e03202adbba9

# Semantic Scholar API (Literature search with citation data)
# 🔑 HOW TO GET: https://www.semanticscholar.org/product/api#api-key-form
# Fill form → get key via email (usually instant)
# ⚠️ ALTERNATIVE IF UNAVAILABLE: Leave empty - code will use Europe PMC + PubMed fallback
# Free tier: 100 requests/5 minutes
SEMANTIC_SCHOLAR_API_KEY=

# CLUE / LINCS Connectivity Map API (Drug connectivity scoring)
# 🔑 HOW TO GET: Register at https://clue.io/
# Then request API access at: https://clue.io/repurposing#api-access
# Academic use: Free after approval (1-2 business days)
# Documentation: https://clue.io/connectopedia/clue_api_overview
CLUE_API_KEY=

# DrugBank API (Drug-drug interactions, targets, pathways)
# 🔑 HOW TO GET: https://go.drugbank.com/releases/latest#open-data
# Academic license: FREE for non-commercial use
# Commercial license: Contact DrugBank for pricing
# ⚠️ NOTE: Academic users download XML dumps (no API key needed)
# API key only for commercial real-time access
DRUGBANK_API_KEY=

# DrugBank Data Files (Downloaded from https://go.drugbank.com/releases/latest#open-data)
# Place downloaded CSV/XML files in the data/ directory
DRUGBANK_VOCABULARY_PATH=data/drugbank_vocabulary.csv
DRUGBANK_STRUCTURES_PATH=data/drugbank_structures.sdf


# ============================================================================
# 📋 PATENT APIs (FREE with Rate Limits)
# ============================================================================

# PatentsView API (No key required, but limited)
# More info: https://patentsview.org/apis/purpose
PATENTSVIEW_API_URL=https://search.patentsview.org/api/v1/patent/

# Google Patents Public Data (BigQuery - requires Google Cloud)
# GOOGLE_CLOUD_PROJECT_ID=your_project_id_here
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json


# ============================================================================
# 💰 MARKET INTELLIGENCE (PAID - Usually Requires Enterprise Access)
# ============================================================================

# IQVIA Market Data (Paid, enterprise only)
# Leave empty to use mock data
IQVIA_API_KEY=
IQVIA_API_URL=

# Bloomberg API (Paid)
BLOOMBERG_API_KEY=


# ============================================================================
# ⚠️ SAFETY & REGULATORY APIs (FREE - FDA)
# ============================================================================

# FDA openFDA API (No key required, but recommended for higher limits)
# Get key at: https://open.fda.gov/apis/authentication/
# Without key: 240 requests/minute, 120,000/day
# With key: 240 requests/minute, 120,000/day (but tracked separately)
FDA_API_KEY=cxpNGvu2drZGIqlCMLVtcVzx4IgzSIKb9Wi8Kdov
FDA_OPENFDA_URL=https://api.fda.gov

# DailyMed API (No key required)
DAILYMED_API_URL=https://dailymed.nlm.nih.gov/dailymed


# ============================================================================
# 🗄️ DATABASE CONFIGURATION (Optional - for storing results)
# ============================================================================

# PostgreSQL Database (Optional)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=drugrepurposing
# DATABASE_PASSWORD=your_secure_password
# DATABASE_NAME=drug_repurposing_db


# ============================================================================
# 🔧 APPLICATION CONFIGURATION
# ============================================================================

# API Server Port
PORT=8000

# Environment (development/production)
ENVIRONMENT=development

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable CORS for frontend
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000


# ============================================================================
# 📊 VECTOR STORE & EMBEDDINGS (Optional - for advanced features)
# ============================================================================

# OpenAI Embeddings (if using OpenAI)
# Already covered by OPENAI_API_KEY above

# Sentence Transformers (Local, no key needed)
# Will download models automatically on first use
USE_LOCAL_EMBEDDINGS=true


# ============================================================================
# 🔒 SECURITY (Production Only)
# ============================================================================

# API Authentication (if needed)
# API_SECRET_KEY=your_secret_key_here
# JWT_SECRET_KEY=your_jwt_secret_here


# ============================================================================
# 🚀 RATE LIMITING (Recommended)
# ============================================================================

# Requests per minute for each API
PUBMED_RATE_LIMIT=3
CLINICALTRIALS_RATE_LIMIT=1
FDA_RATE_LIMIT=240
PUBCHEM_RATE_LIMIT=5
